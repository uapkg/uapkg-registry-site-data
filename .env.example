# Registry source to ingest.
UAPKG_REGISTRY_REPO_OWNER=uapkg
UAPKG_REGISTRY_REPO_NAME=registry-testing
UAPKG_REGISTRY_REPO_REF=main

# Official canonical registry for production can be enabled with:
# UAPKG_REGISTRY_REPO_NAME=registry

# Optional local clone path to avoid network fetch.
UAPKG_REGISTRY_LOCAL_PATH=

# Artifact output directory.
UAPKG_OUTPUT_DIR=./artifacts

# Optional token for API-based README fetches if rate limiting occurs.
UAPKG_GITHUB_TOKEN=

# Default branch used for README fetches in package source repositories.
UAPKG_SOURCE_DEFAULT_BRANCH=main
