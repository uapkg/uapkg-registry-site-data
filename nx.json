{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "tui": {
    "enabled": false
  },
  "namedInputs": {
    "sharedGlobals": ["{workspaceRoot}/biome.json", "{workspaceRoot}/tsconfig.base.json"],
    "default": ["{projectRoot}/**/*", "sharedGlobals"]
  },
  "targetDefaults": {
    "build": {
      "inputs": ["default"]
    },
    "lint": {
      "inputs": ["default"]
    },
    "typecheck": {
      "inputs": ["default"],
      "dependsOn": ["build"]
    },
    "test": {
      "inputs": ["default"],
      "dependsOn": ["build"]
    }
  },
  "plugins": [
    {
      "plugin": "nx/plugins/package-json",
      "options": {
        "targetName": "build"
      }
    }
  ]
}
